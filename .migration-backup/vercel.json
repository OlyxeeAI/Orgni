{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/orgni-app run build",
  "outputDirectory": "artifacts/orgni-app/dist/public",
  "functions": {
    "api/build.js": { "maxDuration": 60 }
  },
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }]
}
