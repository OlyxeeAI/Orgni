# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── AI Provider ───────────────────────────────────────────────────────────────
# Orgni Engine is provider-agnostic. Switch providers by changing these 4 values
# — no code changes required.

# Current default: Anthropic
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.anthropic.com

# Grok (production):
# AI_PROVIDER=grok
# AI_MODEL=grok-3
# AI_API_KEY=xai-your-key-here
# AI_BASE_URL=https://api.x.ai

# OpenAI:
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o
# AI_API_KEY=sk-your-key-here
# AI_BASE_URL=https://api.openai.com

# Any OpenAI-compatible endpoint (local Ollama, vLLM, etc.) also works —
# set AI_PROVIDER to anything other than "anthropic" and point AI_BASE_URL
# at your /v1/chat/completions-compatible server.

# ── Storage [PROTOTYPE] ──────────────────────────────────────────────────────
# lowdb (JSON file) is used for the MVP. See README → Database for the
# PostgreSQL/Supabase migration path — the repository interface is already
# in place, only src/db/index.js needs to change.
DB_PATH=./data/db.json
UPLOAD_DIR=./uploads
LOG_DIR=./logs
LOG_LEVEL=info

# ── Validation ────────────────────────────────────────────────────────────────
# Findings extracted with confidence below this threshold are marked
# "needs_review" instead of "verified".
CONFIDENCE_THRESHOLD=0.75

# ── Testing ───────────────────────────────────────────────────────────────────
# Do not set these manually — the test suite manages them.
# AI_ENABLED=false is implied whenever NODE_ENV=test; this makes `npm test`
# work without a real API key by using a deterministic AI stub.
