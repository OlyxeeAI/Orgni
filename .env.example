PORT=3000

# AI Provider — swap between anthropic, grok, openai, or any OpenAI-compatible endpoint
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.anthropic.com

# For Grok production:
# AI_PROVIDER=grok
# AI_MODEL=grok-3
# AI_API_KEY=xai-your-key-here
# AI_BASE_URL=https://api.x.ai

# For OpenAI:
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o
# AI_API_KEY=sk-your-key-here
# AI_BASE_URL=https://api.openai.com

# Storage
DB_PATH=./data/db.json
UPLOAD_DIR=./uploads
LOG_DIR=./logs
LOG_LEVEL=info

NODE_ENV=development
